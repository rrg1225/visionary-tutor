{
  "name": "visionary-tutor-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "vite",
    "clean:dist": "node scripts/clean-dist.mjs",
    "prepare:pyodide": "node scripts/prepare-pyodide.mjs",
    "prebuild": "npm run clean:dist && npm run prepare:pyodide",
    "build": "vite build && npm run check:bundle",
    "check:bundle": "node scripts/check-bundle-budget.mjs",
    "lint": "eslint --max-warnings=0 src/domain src/adapters src/components/resource tests/unit",
    "format:check": "prettier --check src/domain src/adapters src/components/resource tests/unit eslint.config.js vitest.config.ts",
    "format": "prettier --write src/domain src/adapters src/components/resource tests/unit eslint.config.js vitest.config.ts",
    "test:unit": "vitest run --coverage",
    "quality": "npm run lint && npm run format:check && npm run test:unit && npm run build",
    "preview": "vite preview",
    "pretest:e2e": "npm run clean:dist && vite build --mode e2e && npm run check:bundle",
    "test:e2e": "playwright test",
    "test:e2e:real": "playwright test real-backend",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:serve": "vite preview --host 127.0.0.1 --port 14373 --strictPort",
    "build:android": "npm run clean:dist && npm run prepare:pyodide && vite build --mode android && npm run check:bundle",
    "build:windows": "npm run clean:dist && npm run prepare:pyodide && vite build --mode windows && npm run check:bundle",
    "sync:android": "npm run build:android && cap sync android",
    "package:android": "npm run sync:android && cd android && gradlew.bat assembleDebug",
    "start:windows": "electron .",
    "package:windows": "npm run build:windows && electron-builder --win nsis --x64"
  },
  "dependencies": {
    "@capacitor/core": "^8.4.2",
    "@mediapipe/tasks-vision": "^0.10.32",
    "axios": "^1.9.0",
    "dompurify": "^3.2.6",
    "element-plus": "^2.9.11",
    "katex": "^0.16.22",
    "markdown-it": "^14.1.0",
    "mermaid": "^11.6.0",
    "pinia": "^2.3.1",
    "pyodide": "^0.26.4",
    "vue": "^3.5.34",
    "vue-router": "^4.5.1"
  },
  "devDependencies": {
    "@capacitor/android": "^8.4.2",
    "@capacitor/cli": "^8.4.2",
    "@playwright/test": "^1.51.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@vitejs/plugin-vue": "^6.0.6",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "electron": "^43.1.1",
    "electron-builder": "^26.15.3",
    "esbuild": "^0.28.0",
    "eslint": "^9.30.1",
    "eslint-plugin-vue": "^10.3.0",
    "globals": "^16.3.0",
    "jsdom": "^26.1.0",
    "prettier": "^3.6.2",
    "typescript-eslint": "^8.36.0",
    "vite": "^8.0.12",
    "vitest": "^3.2.4"
  },
  "build": {
    "appId": "com.visionary.tutor",
    "productName": "智途 Agent",
    "asar": true,
    "directories": {
      "output": "release/windows",
      "buildResources": "build-resources"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "build-resources/icon.png",
      "artifactName": "VisionaryTutor-Setup-${version}-${arch}.${ext}"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "智途 Agent",
      "uninstallDisplayName": "智途 Agent",
      "runAfterFinish": true
    }
  }
}
