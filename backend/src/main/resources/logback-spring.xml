<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <!-- 从 application.yml 读取日志配置 -->
    <springProperty scope="context" name="CONSOLE_LOG_PATTERN" source="logging.pattern.console"
                    defaultValue="%d{yyyy-MM-dd HH:mm:ss} [%thread] %-5level %logger{36} - %msg%n"/>

    <!-- 强制禁用 Jansi 控制台输出，避免调用本地 DLL 引起冲突 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <withJansi>false</withJansi>
        <encoder>
            <pattern>${CONSOLE_LOG_PATTERN}</pattern>
            <charset>UTF-8</charset>
        </encoder>
    </appender>

    <!-- 默认应用级别，可通过 application.yml 中的 logging.level.* 覆盖 -->
    <root level="INFO">
        <appender-ref ref="CONSOLE" />
    </root>
</configuration>
