<?xml version="1.0" encoding="UTF-8"?>
<FindBugsFilter>
    <!-- JPA entities and generated Lombok methods are framework-managed. -->
    <Match>
        <Package name="com.visionary.entity"/>
    </Match>
    <Match>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>
</FindBugsFilter>
