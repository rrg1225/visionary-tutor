# 智眸学伴后端环境变量示例
# 复制为 backend/.env.properties 后填入真实密钥

# DeepSeek / 通用 LLM
DEEPSEEK_API_KEY=sk-xxx
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# 阿里云 DashScope（通义千问 / Embedding / TTS / 文生图 / Rerank）
DASHSCOPE_API_KEY=sk-xxx
QWEN_VL_MAX_KEY=sk-xxx
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_PROVIDER=dashscope
EMBEDDING_MODEL_NAME=text-embedding-v4
DASHSCOPE_IMAGE_MODEL=wanx-v1
DASHSCOPE_RERANK_MODEL=gte-rerank

# 阿里云 OSS（视频/资源归档）
ALIYUN_OSS_ACCESS_KEY=xxx
ALIYUN_OSS_SECRET_KEY=xxx

# 讯飞星火（情绪分析 Spark HTTP API + TTS 备用）
XUNFEI_SPARK_MAX_KEY=你的讯飞APIKey
XUNFEI_SPARK_VOICE_KEY=你的讯飞APIKey
XUNFEI_TTS_API_KEY=你的讯飞APIKey
XUNFEI_APP_ID=你的讯飞AppId
XUNFEI_API_SECRET=你的讯飞ApiSecret
XUNFEI_TTS_URL=wss://tts-api.xfyun.cn/v2/tts
XUNFEI_TTS_AUE=lame
XUNFEI_TTS_CONNECT_TIMEOUT_SECONDS=15
XUNFEI_TTS_RESPONSE_TIMEOUT_SECONDS=30
XUNFEI_TTS_MAX_AUDIO_BYTES=10485760
# 可选：XUNFEI_SPARK_BASE_URL=https://spark-api-open.xf-yun.com/v4

# 智谱视频生成（CogVideoX）
ZHIPU_API_KEY=你的智谱APIKey
ZHIPU_BASE_URL=https://open.bigmodel.cn/api/paas/v4
ZHIPU_VIDEO_MODEL=cogvideox-3

# MCP (Model Context Protocol) — 标准外部工具总线
AGENT_MCP_ENABLED=false
AGENT_MCP_FILESYSTEM_ENABLED=false
AGENT_MCP_FILESYSTEM_ROOT=./ai_engine/knowledge_base
AGENT_MCP_NPX_COMMAND=npx
AGENT_MCP_TIMEOUT_MS=15000

# 数据库 / Redis / Chroma
DB_URL=jdbc:mysql://127.0.0.1:3306/visionary_tutor?useUnicode=true&characterEncoding=utf8&serverTimezone=Asia/Shanghai&useSSL=false&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=change-me
REDIS_HOST=localhost
REDIS_PORT=6379
CHROMA_HOST=127.0.0.1
CHROMA_PORT=8000

# 密码找回邮件（SMTP）
APP_PUBLIC_BASE_URL=https://your-domain.example
MAIL_FROM=no-reply@your-domain.example
SPRING_MAIL_HOST=smtp.example.com
SPRING_MAIL_PORT=587
SPRING_MAIL_USERNAME=no-reply@your-domain.example
SPRING_MAIL_PASSWORD=change-me
SPRING_MAIL_SMTP_AUTH=true
SPRING_MAIL_STARTTLS_ENABLE=true

# 其他
SPRING_PROFILES_ACTIVE=dev
VECTOR_DIMENSION=1024
